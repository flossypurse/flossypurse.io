---
// Geometric animation component
---
<canvas id="geometric-canvas" class="fixed inset-0 w-full h-full z-0"></canvas>

<script>
  const canvas = document.getElementById('geometric-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  let width = window.innerWidth;
  let height = window.innerHeight;

  canvas.width = width;
  canvas.height = height;

  // Geometric shapes that rotate and move
  interface Shape {
    x: number;
    y: number;
    size: number;
    rotation: number;
    rotationSpeed: number;
    dx: number;
    dy: number;
    type: 'triangle' | 'square' | 'hexagon';
    opacity: number;
    color: string;
  }

  const shapes: Shape[] = [];
  const colors = ['#0ea5e9', '#06b6d4', '#3b82f6', '#8b5cf6'];

  // Create initial shapes - MORE VISIBLE
  for (let i = 0; i < 12; i++) {
    shapes.push({
      x: Math.random() * width,
      y: Math.random() * height,
      size: Math.random() * 80 + 60,  // Bigger
      rotation: Math.random() * Math.PI * 2,
      rotationSpeed: (Math.random() - 0.5) * 0.015,
      dx: (Math.random() - 0.5) * 0.8,  // Faster
      dy: (Math.random() - 0.5) * 0.8,
      type: ['triangle', 'square', 'hexagon'][Math.floor(Math.random() * 3)] as any,
      opacity: Math.random() * 0.3 + 0.3,  // Very visible: 0.3-0.6
      color: colors[Math.floor(Math.random() * colors.length)]
    });
  }

  // Initial full clear
  ctx.fillStyle = '#020617';
  ctx.fillRect(0, 0, width, height);

  function drawTriangle(x: number, y: number, size: number) {
    ctx.beginPath();
    ctx.moveTo(x, y - size / 2);
    ctx.lineTo(x - size / 2, y + size / 2);
    ctx.lineTo(x + size / 2, y + size / 2);
    ctx.closePath();
    ctx.fill();
  }

  function drawSquare(x: number, y: number, size: number) {
    ctx.fillRect(x - size / 2, y - size / 2, size, size);
  }

  function drawHexagon(x: number, y: number, size: number) {
    ctx.beginPath();
    for (let i = 0; i < 6; i++) {
      const angle = (Math.PI / 3) * i;
      const hx = x + size * Math.cos(angle);
      const hy = y + size * Math.sin(angle);
      if (i === 0) ctx.moveTo(hx, hy);
      else ctx.lineTo(hx, hy);
    }
    ctx.closePath();
    ctx.fill();
  }

  function animate() {
    // Clear with semi-transparent background for trail effect
    ctx.fillStyle = 'rgba(2, 6, 23, 0.08)';  // Subtle trails
    ctx.fillRect(0, 0, width, height);

    shapes.forEach(shape => {
      shape.x += shape.dx;
      shape.y += shape.dy;
      shape.rotation += shape.rotationSpeed;

      // Wrap around edges
      if (shape.x < -shape.size) shape.x = width + shape.size;
      if (shape.x > width + shape.size) shape.x = -shape.size;
      if (shape.y < -shape.size) shape.y = height + shape.size;
      if (shape.y > height + shape.size) shape.y = -shape.size;

      ctx.save();
      ctx.translate(shape.x, shape.y);
      ctx.rotate(shape.rotation);
      ctx.fillStyle = shape.color;
      ctx.globalAlpha = shape.opacity;

      if (shape.type === 'triangle') drawTriangle(0, 0, shape.size);
      else if (shape.type === 'square') drawSquare(0, 0, shape.size);
      else drawHexagon(0, 0, shape.size / 2);

      ctx.restore();
    });

    requestAnimationFrame(animate);
  }

  animate();

  window.addEventListener('resize', () => {
    width = window.innerWidth;
    height = window.innerHeight;
    canvas.width = width;
    canvas.height = height;
  });
</script>
