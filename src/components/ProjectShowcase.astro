---
const projects = [
  {
    id: "resonatehq-io",
    name: "resonatehq.io",
    tagline: "Company website for Resonate HQ",
    description:
      "Built the marketing site for Resonate with interactive demos showcasing durable execution concepts. Features custom animations, code examples, and a spectrum visualizer that brings the framework to life.",
    tags: ["Next.js", "TypeScript", "React", "Vercel"],
    link: "https://resonatehq.io"
  },
  {
    id: "docs-resonatehq-io",
    name: "docs.resonatehq.io",
    tagline: "Comprehensive framework documentation",
    description:
      "Created and maintain the documentation site for Resonate, including getting started guides, API references, tutorials, and deployment guides. Built with Docusaurus and deployed via Vercel.",
    tags: ["Docusaurus", "MDX", "TypeScript", "Technical Writing"],
    link: "https://docs.resonatehq.io"
  },
  {
    id: "agent-skills",
    name: "Resonate Agent Skills",
    tagline: "Claude skills for durable execution",
    description:
      "Developed specialized agent skills that help Claude understand and build with Resonate. Covers TypeScript development, debugging, deployment, and advanced reasoning about distributed systems.",
    tags: ["AI", "Claude", "Developer Tools", "Documentation"],
    link: "https://docs.resonatehq.io"
  },
  {
    id: "examples",
    name: "Example Applications",
    tagline: "Real-world Resonate patterns",
    description:
      "Building a library of example applications demonstrating AI agents, workflows, pipelines, and services. Each example shows how to solve real problems with durable execution.",
    tags: ["TypeScript", "Resonate SDK", "Patterns", "Examples"],
    link: "https://github.com/resonatehq-examples"
  }
];
---
<section id="work" class="mx-auto mt-24 w-full max-w-6xl px-6">
  <div class="flex flex-col gap-10">
    <div class="flex flex-col gap-4">
      <div>
        <h2 class="section-title">Projects</h2>
        <p class="section-subtitle">
          Building the web presence, documentation, and developer tools for Resonate HQ.
        </p>
      </div>
    </div>
    <div class="grid gap-6 md:grid-cols-2" data-showcase-grid>
      {projects.map((project, index) => (
        <article
          class={`card group flex flex-col justify-between rounded-2xl p-8 transition-all duration-300 hover:-translate-y-1 hover:border-sky-400/60 hover:shadow-xl hover:shadow-sky-500/20`}
          data-card={project.id}
        >
          <div class="space-y-4">
            <div class="flex items-center justify-between">
              <span class="chip">{String(index + 1).padStart(2, '0')}</span>
              <i class="i-lucide-external-link text-slate-400"></i>
            </div>
            <h3 class="font-display text-2xl text-white">{project.name}</h3>
            <p class="text-sm font-medium text-sky-300">{project.tagline}</p>
            <p class="text-sm text-slate-300 leading-relaxed">{project.description}</p>
          </div>
          <div class="mt-6 flex flex-wrap gap-2">
            {project.tags.map((tag) => (
              <span class="text-xs px-3 py-1 rounded-full bg-slate-800/50 text-slate-400 border border-slate-700/50">{tag}</span>
            ))}
          </div>
          <a
            class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-sky-300 hover:text-sky-200 transition-colors"
            href={project.link}
            target="_blank"
            rel="noopener noreferrer"
          >
            View project
            <i class="i-lucide-external-link"></i>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
